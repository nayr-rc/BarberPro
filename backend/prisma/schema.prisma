// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String
  phone     String?
  role      String     @default("client") // "client" or "admin"
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  // Relations
  appointments Appointment[]
  
  @@map("users")
}

model Barber {
  id        String     @id @default(cuid())
  name      String
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  
  // Relations
  appointments Appointment[]
  
  @@map("barbers")
}

model Service {
  id              String     @id @default(cuid())
  name            String
  price           Float
  durationMinutes Int
  active          Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  // Relations
  appointments Appointment[]
  
  @@map("services")
}

model Appointment {
  id               String     @id @default(cuid())
  userId           String?    // Torna-se opcional para convidados
  guestName        String?    
  guestPhone       String?
  barberId         String
  serviceId        String
  datetimeStart    DateTime
  datetimeEnd      DateTime
  status           String     @default("confirmed") 
  cancelledBy      String?    
  paymentStatus    String     @default("pending") // pending, paid, expired
  paymentExpiresAt DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  
  // Relations
  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  barber          Barber      @relation(fields: [barberId], references: [id], onDelete: Restrict)
  service         Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  appointmentDrinks AppointmentDrink[]
  
  @@map("appointments")
}

model Drink {
  id        String   @id @default(cuid())
  name      String
  price     Float
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointmentDrinks AppointmentDrink[]

  @@map("drinks")
}

model AppointmentDrink {
  id            String   @id @default(cuid())
  appointmentId String
  drinkId       String
  quantity      Int      @default(1)

  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  drink         Drink       @relation(fields: [drinkId], references: [id], onDelete: Restrict)

  @@map("appointment_drinks")
}
