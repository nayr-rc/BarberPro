{
  "name": "barbearia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:backend:unit:critical": "npm --prefix barbershop-api run test -- tests/unit/middlewares/auth.test.js tests/unit/middlewares/checkSubscription.test.js tests/unit/validations/custom.validation.test.js tests/unit/services/service.service.test.js tests/unit/services/serviceCategory.service.test.js tests/unit/services/review.service.test.js tests/unit/services/appointment.service.test.js",
    "test:backend:e2e:critical": "npm --prefix barbershop-api run test -- tests/e2e/auth-appointments.e2e.test.js",
    "test:pre-commit": "npm run test:backend:unit:critical",
    "test:pre-push": "npm run test:backend:unit:critical && npm run test:backend:e2e:critical",
    "prepare": "husky"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "axios": "^1.6.5",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.564.0",
    "next": "16.2.0-canary.71",
    "react": "19.2.3",
    "react-calendar": "^6.0.0",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.48.1",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0-canary.71",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
